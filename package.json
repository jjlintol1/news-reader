{
  "name": "news-reader",
  "version": "1.0.0",
  "private": true,
  "description": "Flipboard-style news reader with React + Vite frontend and Express proxy backend",
  "scripts": {
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "web:dev": "cd web && npm run dev",
    "dev": "concurrently --kill-others-on-fail \"npm run server:dev\" \"npm run web:dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
